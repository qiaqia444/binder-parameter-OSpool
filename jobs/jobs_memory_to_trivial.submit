# HTCondor submit file for Memory-to-Trivial Transition Scan
# Phase transition with fixed measurement strengths and density matrix evolution

universe              = vanilla
executable            = run_memory_to_trivial.sh
arguments             = $(L) $(lambda_x) $(lambda_zz) $(P_x) $(P_zz) $(ntrials) $(seed) $(sample) $(out_prefix)

# Send only what the job needs
transfer_input_files  = ../src_new, ../Project.toml, ../Manifest.toml, ../run_memory_to_trivial_scan.jl

should_transfer_files   = YES
when_to_transfer_output = ON_EXIT
transfer_output_files   = output

# Logs (on submit node)
output                = logs/memory_to_trivial_L$(L)_Px$(P_x)_s$(sample).out
error                 = logs/memory_to_trivial_L$(L)_Px$(P_x)_s$(sample).err
log                   = logs/memory_to_trivial_condor.log

+JobDurationCategory = "Long"

# Resources (density matrices need more memory than pure states)
# T_max = 50L with multi-threading (4 CPUs)
request_cpus          = 4
request_memory        = 8GB
request_disk          = 8 GB

# Use your working container
container_image = /ospool/ap40/data/qia.wang/container.sif

# One job per line in params_memory_to_trivial.txt
queue L lambda_x lambda_zz P_x P_zz ntrials seed sample out_prefix from params_memory_to_trivial.txt
